generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  role            String    @default("STUDENT")
  schoolId        String?
  verified        Boolean   @default(true)
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime  @default(now())
  accounts        Account[]
  sessions        Session[]

  // CEAT Relational Mappings
  borrowRequests  BorrowRequest[] @relation("StudentRequests")
  approvedRequests BorrowRequest[] @relation("ProfessorApprovals")
  auditLogs       AuditLog[]      @relation("UserAuditLogs")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------------------------
// Phase 2: CEAT Dispensing Specific Tables
// ----------------------------------------------------------------------

enum ItemStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum RequestStatus {
  PENDING
  APPROVED
  DISPENSED
  RETURNED
  REJECTED
  EXPIRED
}

model InventoryItem {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  totalQty      Int      @default(0)
  availableQty  Int      @default(0)
  status        ItemStatus @default(ACTIVE)
  
  borrowItems   BorrowRequestItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BorrowRequest {
  id            String   @id @default(cuid())
  
  // Relations
  studentId     String
  student       User     @relation("StudentRequests", fields: [studentId], references: [id])
  
  professorId   String?
  professor     User?    @relation("ProfessorApprovals", fields: [professorId], references: [id])
  
  // Data
  roomNumber       String
  status           RequestStatus @default(PENDING)
  isGroup          Boolean  @default(false)

  // Individual requester identity (denormalized for audit trail clarity)
  studentName      String?   // Captured at request time
  studentSchoolId  String?   // Captured at request time

  // Details
  groupMembers  GroupMember[]
  items         BorrowRequestItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BorrowRequestItem {
  id            String   @id @default(cuid())
  
  requestId     String
  request       BorrowRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  itemId        String
  item          InventoryItem @relation(fields: [itemId], references: [id])
  
  quantity      Int
}

model GroupMember {
  id               String   @id @default(cuid())
  
  requestId        String
  request          BorrowRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  studentName      String
  schoolIdNumber   String
}

model AuditLog {
  id            String   @id @default(cuid())

  actorId       String
  actor         User     @relation("UserAuditLogs", fields: [actorId], references: [id])
  actorRole     String   @default("UNKNOWN") // Role at time of action

  action        String   // e.g., "CREATED_REQUEST", "DISPENSED_ITEM"
  entityId      String?  // References the request or item ID
  details       String?  @db.Text // Rich human-readable description of the action

  createdAt     DateTime @default(now())
}
